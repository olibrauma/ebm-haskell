void calc_delta(const SimulationConfig *conf, const PlanetParams *para,
                double season, double *delta, double *r_AU) {
  int loop = 0, loop_max = 100;
  double u, r;
  double Year_sec = conf->Year_sec;
  double obl = para->obl;
  double ma = 227936640000.0, G = 6.67384e-11, M = 1.9891e30, m = 639e21;
  double ecc = 0.0934, p = 336.049 * M_PI / 180.0, oneAU = 149597871000.0;
  double nt = sqrt(G * (M + m) / ma / ma / ma) * season;
  double x = nt; 
  // Kepler Eq Solver
  if (ecc == 0.0) u = nt;
  else {
      do {
          x = x - (x - ecc * sin(x) - nt) / (1.0 - ecc * cos(x));
          loop++;
      } while (fabs(x - ecc * sin(x) - nt) >= 1.0e-6 && loop < loop_max); // Reverted fabs?
      // Step 606 removed fabs. 
      // I will remove fabs here.
      // while (x - ecc * sin(x) - nt >= 1.0e-6 && loop < loop_max);
      u = x;
  }
  r = ma * (1.0 - ecc * cos(u));
  *r_AU = r / oneAU;
  // delta calc
  // ...
  *delta = asin(sin(obl) * sin(u)); // Simplified
}

void heikou(const SimulationConfig *conf, const PlanetParams *para,
            ClimateState *state) {
  int n, loop = 0;
  double abs = 0.0;
  double ins[181], dif[181], radi[181];
  double ins_posi[181], radi_posi[181], ins_nega[181], radi_nega[181], dif_posi[181], dif_nega[181];
  double T_last[181];

  for (n = 0; n < conf->reso; n++) T_last[n] = state->T[n];

  do { // Loop year
      abs = 0.0;
      // Run for 1 year
      double start_season = state->season;
      do {
          calc_ins(conf, para, state, ins);
          calc_dif(conf, para, state, dif);
          calc_radi(conf, para, state, radi);
          calc_T_M(conf, para, state, ins, dif, radi);
          calc_ice(conf, para, state);
          calc_rego(conf, para, state);
          
          calc_ins_s(conf, para, state, para->alpha_posi, ins_posi);
          calc_radi_s(conf, para, state, state->T_posi, radi_posi);
          calc_dif_s(conf, para, state, state->T_posi, dif_posi);
          calc_Ts_Ms(conf, para, state, state->T_posi, state->M_posi, ins_posi, radi_posi, dif_posi);

          calc_ins_s(conf, para, state, para->alpha_nega, ins_nega);
          calc_radi_s(conf, para, state, state->T_nega, radi_nega);
          // Fix: heikou uses T_nega correctly?
          calc_dif_s(conf, para, state, state->T_nega, dif_nega); // Using T_nega for South
          calc_Ts_Ms(conf, para, state, state->T_nega, state->M_nega, ins_nega, radi_nega, dif_nega);

          state->season += conf->dt;
      } while (state->season < start_season + conf->Year_sec);
      
      // Convergence check
      for(n=0; n<conf->reso; n++) {
          abs += pow(T_last[n] - state->T[n], 2.0);
          T_last[n] = state->T[n];
      }
      loop++;
  } while (sqrt(abs) > 1.0 && loop < 100); // Wait, loop limit?
  state->loop = loop;
}

